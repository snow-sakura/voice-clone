# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# local data
data/*

# 安全文件存储（非 public）
/uploads/*
/tts_output/*
!.gitkeep

# 遗留的 public 目录文件
public/uploads/*
public/tts_output/*

# design references
/readdy/
/screenshots/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
